import telebot
import csv
import requests
import io

TOKEN = "8668461577:AAHisD8fV_0GqXAXoU57FXOeexTi2x1yI74"
CSV_URL = "https://baz-on.ru/export/c592/e61a0/stuttgart-drom.csv"

bot = telebot.TeleBot(TOKEN)

parts_db = []

number_key = None
name_key = None
photo_key = None


def load_database():

    global parts_db, number_key, name_key, photo_key

    print("Загрузка базы...")

    r = requests.get(CSV_URL)
    r.encoding = "cp1251"

    text = r.text

    csv_file = io.StringIO(text)

    reader = csv.DictReader(csv_file, delimiter=";")

    headers = reader.fieldnames

    print("Колонки CSV:", headers)

    for h in headers:

        h_low = h.lower()

        if "номер" in h_low or "артикул" in h_low:
            number_key = h

        if "наимен" in h_low:
            name_key = h

        if "фото" in h_low or "photo" in h_low:
            photo_key = h

    print("Колонка номера:", number_key)
    print("Колонка названия:", name_key)
    print("Колонка фото:", photo_key)

    parts_db.clear()

    for row in reader:
        parts_db.append(row)

    print(f"База загружена: {len(parts_db)} деталей")


def find_part(query):

    query = query.lower().strip()

    results = []

    for part in parts_db:

        number = str(part.get(number_key, "")).lower()
        name = str(part.get(name_key, "")).lower()

        if query in number or query in name:

            results.append(part)

        if len(results) >= 5:
            break

    return results


def keyboard():

    kb = telebot.types.ReplyKeyboardMarkup(resize_keyboard=True)
    kb.add("🚗 Найти запчасть")

    return kb


@bot.message_handler(commands=["start"])
def start(msg):

    bot.send_message(
        msg.chat.id,
        "🚗 Бот поиска автозапчастей",
        reply_markup=keyboard()
    )


@bot.message_handler(func=lambda m: m.text == "🚗 Найти запчасть")
def ask(msg):

    bot.send_message(msg.chat.id, "Введите номер детали:")


@bot.message_handler(func=lambda m: True)
def search(msg):

    results = find_part(msg.text)

    if not results:

        bot.send_message(msg.chat.id, "❌ Деталь не найдена")
        return

    for p in results:

        number = p.get(number_key, "")
        name = p.get(name_key, "")
        brand = p.get("Марка", "")
        model = p.get("Модель", "")
        price = p.get("Цена", "")
        status = p.get("Статус", "")
        photos = p.get(photo_key, "")

        text = (
            f"🔧 {name}\n"
            f"Номер: {number}\n"
            f"Авто: {brand} {model}\n"
            f"Цена: {price} ₽\n"
            f"{status}"
        )

        if photos:

            photo_list = [p.strip() for p in photos.split(",") if p.strip()]

            try:

                media = []

                for i, photo in enumerate(photo_list):

                    if i == 0:
                        media.append(
                            telebot.types.InputMediaPhoto(
                                photo,
                                caption=text
                            )
                        )
                    else:
                        media.append(
                            telebot.types.InputMediaPhoto(photo)
                        )

                bot.send_media_group(msg.chat.id, media)

            except:

                bot.send_message(msg.chat.id, text)

        else:

            bot.send_message(msg.chat.id, text)


if __name__ == "__main__":

    load_database()

    print("BOT STARTED")

    bot.infinity_polling()
