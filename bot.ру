# ===== ЗАГРУЗКА CSV =====
def load_csv(url):
    headers = {"User-Agent": "Mozilla/5.0"}
    r = requests.get(url, headers=headers, timeout=30)
    r.encoding = "cp1251"

    csv_file = io.StringIO(r.text)
    reader = csv.DictReader(csv_file, delimiter=";")

    return list(reader), reader.fieldnames

def load_database():
    global parts_db, wheels_db, number_key, name_key, photo_key

    parts_db, headers = load_csv(PARTS_CSV)
    wheels_db, headers2 = load_csv(WHEELS_CSV)

    for h in headers:
        h_low = h.lower()

        if "артикул" in h_low or "номер" in h_low:
            number_key = h

        if "наимен" in h_low or "название" in h_low:
            name_key = h

        if "фото" in h_low or "image" in h_low:
            photo_key = h

# ===== ПОИСК =====
def find_part(query, db):
    query = query.lower()
    words = query.split()

    query_type = detect_part_type(query)

    results = []

    for part in db:
        name = str(part.get(name_key, "")).lower()

        part_type = detect_part_type(name)

        # 💣 ЖЁСТКИЙ ФИЛЬТР ТИПА
        if query_type:
            if not part_type:
                continue

            if part_type != query_type:
                continue

            # 🔥 ДОПОЛНИТЕЛЬНО: исключаем "усилитель бампера"
            if not name.startswith(query_type):
                continue

        # 🔍 проверка слов
        if all(word in name for word in words):
            results.append(part)

    return results[:10]

def find_smart(query, db):
    words = query.lower().split()
    results = []

    for part in db:
        text = " ".join(str(v).lower() for v in part.values())

        score = 0
        for word in words:
            if word in text:
                score += 1

        if score > 0:
            results.append((score, part))

    results.sort(key=lambda x: x[0], reverse=True)

    return [r[1] for r in results[:10]]

def find_wheels(query, db):
    query = query.lower().replace(" ", "")

    results = []

    for part in db:
        radius = str(part.get("Диаметр диска", "")).lower()

        if query in radius or query in "r" + radius:
            results.append(part)

        if len(results) >= 10:
            break

    return results


