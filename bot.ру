import csv
import requests
import io
from telebot.types import InputMediaPhoto, InlineKeyboardMarkup, InlineKeyboardButton

TOKEN = "8668461577:AAHisD8fV_0GqXAXoU57FXOeexTi2x1yI74"
CSV_URL = "https://baz-on.ru/export/c592/e61a0/stuttgart-drom.csv"

bot = telebot.TeleBot(TOKEN)

parts_db = []
number_key = None
name_key = None

# хранение результатов поиска пользователя
user_results = {}


# -----------------------------
# загрузка базы
# -----------------------------
def load_database():

    global parts_db, number_key, name_key

    print("Загрузка базы...")

    r = requests.get(CSV_URL)
    r.encoding = "cp1251"

    csv_file = io.StringIO(r.text)
    reader = csv.DictReader(csv_file, delimiter=";")

    headers = reader.fieldnames

    for h in headers:
        h_low = h.lower()

        if "артикул" in h_low or "номер" in h_low:
            number_key = h

        if "наимен" in h_low:
            name_key = h

    parts_db.clear()

    for row in reader:
        parts_db.append(row)

    print("База загружена:", len(parts_db))


# -----------------------------
# поиск
# -----------------------------
def find_part(query):

    query = query.lower().replace(" ", "")

    results = []

    for part in parts_db:

        number = str(part.get(number_key, "")).lower().replace(" ", "")
        name = str(part.get(name_key, "")).lower()

        if query in number or query in name:
            results.append(part)

    return results


# -----------------------------
# клавиатура навигации
# -----------------------------
def nav_keyboard(index, total):

    kb = InlineKeyboardMarkup()

    kb.row(
        InlineKeyboardButton("⬅️", callback_data="prev"),
        InlineKeyboardButton(f"{index+1}/{total}", callback_data="info"),
        InlineKeyboardButton("➡️", callback_data="next")
    )

    return kb


# -----------------------------
# отправка карточки детали
# -----------------------------
def send_part(chat_id, part, index, total):

    number = part.get(number_key, "")
    name = part.get(name_key, "")
    brand = part.get("Марка", "")
    model = part.get("Модель", "")
    price = part.get("Цена", "")
    status = part.get("Статус", "")
    photo_field = part.get("Фото", "").strip()

    text = (
        f"🚗 Найдено:\n\n"
        f"🔧 {name}\n"
        f"Номер: {number}\n"
        f"Авто: {brand} {model}\n"
        f"Цена: {price} ₽\n"
        f"{status}"
    )

    kb = nav_keyboard(index, total)

    if photo_field:

        photos = [p.strip() for p in photo_field.split(",") if p.strip()]

        media = []

        for i, ph in enumerate(photos[:5]):

            if i == 0:
                media.append(InputMediaPhoto(ph, caption=text))
            else:
                media.append(InputMediaPhoto(ph))

        try:
            bot.send_media_group(chat_id, media)
            bot.send_message(chat_id, "Навигация:", reply_markup=kb)
        except:
            bot.send_message(chat_id, text, reply_markup=kb)

    else:

        bot.send_message(chat_id, text, reply_markup=kb)


# -----------------------------
# старт
# -----------------------------
@bot.message_handler(commands=["start"])
def start(msg):

    kb = telebot.types.ReplyKeyboardMarkup(resize_keyboard=True)
    kb.add("🚗 Найти запчасть")

    bot.send_message(
        msg.chat.id,
        "🚗 Бот поиска автозапчастей\n\nВведите номер детали",
        reply_markup=kb
    )


# -----------------------------
# поиск
# -----------------------------
@bot.message_handler(func=lambda m: True)
def search(msg):

    query = msg.text

    results = find_part(query)

    if not results:

        bot.send_message(msg.chat.id, "❌ Деталь не найдена")
        return

    user_results[msg.chat.id] = {
        "results": results,
        "index": 0
    }

    send_part(msg.chat.id, results[0], 0, len(results))


# -----------------------------
# обработка кнопок
# -----------------------------
@bot.callback_query_handler(func=lambda call: True)
def callbacks(call):

    chat_id = call.message.chat.id

    if chat_id not in user_results:
        return
    data = user_results[chat_id]

    results = data["results"]
    index = data["index"]

    if call.data == "next":
        index = (index + 1) % len(results)

    elif call.data == "prev":
        index = (index - 1) % len(results)

    data["index"] = index

    send_part(chat_id, results[index], index, len(results))


# -----------------------------
# запуск
# -----------------------------
if __name__ == "__main__":

    load_database()

    print("BOT STARTED")

    bot.infinity_polling()
