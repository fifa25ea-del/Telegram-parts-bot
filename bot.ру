# ===== ЗАГРУЗКА CSV =====
def load_csv(url):
    headers = {"User-Agent": "Mozilla/5.0"}
    r = requests.get(url, headers=headers, timeout=30)
    r.encoding = "cp1251"

    csv_file = io.StringIO(r.text)
    reader = csv.DictReader(csv_file, delimiter=";")

    return list(reader), reader.fieldnames


def load_database():
    global parts_db, wheels_db, number_key, name_key, photo_key

    parts_db, headers = load_csv(PARTS_CSV)
    wheels_db, headers2 = load_csv(WHEELS_CSV)

    # 🔥 принудительно задаём ключи (фикс бага)
    for h in headers:
        h_low = h.lower()

        if "артикул" in h_low or "номер" in h_low:
            number_key = h

        if "наимен" in h_low or "название" in h_low:
            name_key = h

        if "фото" in h_low or "image" in h_low:
            photo_key = h

