import telebot
import csv
import requests
import io

TOKEN = "8668461577:AAHisD8fV_0GqXAXoU57FXOeexTi2x1yI74"
CSV_URL = "https://baz-on.ru/export/c592/e61a0/stuttgart-drom.csv"

bot = telebot.TeleBot(TOKEN)

parts_db = []
number_key = None
name_key = None


# -----------------------------
# загрузка базы
# -----------------------------
def load_database():

    global parts_db, number_key, name_key

    print("Загрузка базы...")

    r = requests.get(CSV_URL)
    r.encoding = "cp1251"

    csv_text = r.text

    csv_file = io.StringIO(csv_text)

    reader = csv.DictReader(csv_file, delimiter=";")

    headers = reader.fieldnames

    print("Колонки CSV:", headers)

    for h in headers:

        h_low = h.lower()

        if "артикул" in h_low or "номер" in h_low:
            number_key = h

        if "наимен" in h_low:
            name_key = h

    print("Колонка номера:", number_key)
    print("Колонка названия:", name_key)

    parts_db.clear()

    for row in reader:
        parts_db.append(row)

    print("База загружена:", len(parts_db))


# -----------------------------
# поиск детали
# -----------------------------
def find_part(query):

    query = query.lower().replace(" ", "")

    results = []

    for part in parts_db:

        number = str(part.get(number_key, "")).lower().replace(" ", "")
        name = str(part.get(name_key, "")).lower()

        if query in number or query in name:

            results.append(part)

        if len(results) >= 5:
            break

    return results


# -----------------------------
# клавиатура
# -----------------------------
def keyboard():

    kb = telebot.types.ReplyKeyboardMarkup(resize_keyboard=True)

    kb.add("🚗 Найти запчасть")

    return kb


# -----------------------------
# старт
# -----------------------------
@bot.message_handler(commands=["start"])
def start(msg):

    bot.send_message(
        msg.chat.id,
        "🚗 Бот поиска автозапчастей\n\nНажмите кнопку ниже",
        reply_markup=keyboard()
    )


# -----------------------------
# кнопка поиска
# -----------------------------
@bot.message_handler(func=lambda m: m.text == "🚗 Найти запчасть")
def ask(msg):

    bot.send_message(msg.chat.id, "Введите номер детали:")


# -----------------------------
# обработка поиска
# -----------------------------
@bot.message_handler(func=lambda m: True)
def search(msg):

    query = msg.text

    results = find_part(query)

    if not results:

        bot.send_message(msg.chat.id, "❌ Деталь не найдена")
        return

    for p in results:

        number = p.get(number_key, "")
        name = p.get(name_key, "")
        brand = p.get("Марка", "")
        model = p.get("Модель", "")
        price = p.get("Цена", "")
        status = p.get("Статус", "")
        photo_field = p.get("Фото", "").strip()

        text = (
            f"🚗 Найдено:\n\n"
            f"🔧 {name}\n"
            f"Номер: {number}\n"
            f"Авто: {brand} {model}\n"
            f"Цена: {price} ₽\n"
            f"{status}"
        )

        if photo_field:

            photos = [p.strip() for p in photo_field.split(",") if p.strip()]

            try:

                # первое фото с описанием
                bot.send_photo(msg.chat.id, photos[0], caption=text)

                # остальные фото (максимум 2)
                for ph in photos[1:3]:
                    bot.send_photo(msg.chat.id, ph)

            except:

                bot.send_message(msg.chat.id, text)

        else:

            bot.send_message(msg.chat.id, text)


# -----------------------------
# запуск
# -----------------------------
if __name__ == "__main__":

    load_database()

    print("BOT STARTED")

    bot.infinity_polling()
