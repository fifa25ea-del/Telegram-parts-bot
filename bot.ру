import telebot
import csv
import requests
import io

TOKEN = "8668461577:AAHisD8fV_0GqXAXoU57FXOeexTi2x1yI74"
CSV_URL = "https://baz-on.ru/export/c592/e61a0/stuttgart-drom.csv"

bot = telebot.TeleBot(TOKEN)

parts_db = []

number_key = None
name_key = None


# -------------------------
# Загрузка CSV
# -------------------------
def load_database():
    global parts_db, number_key, name_key

    print("Загрузка базы...")

    r = requests.get(CSV_URL)
    r.encoding = "utf-8"

    text = r.text

    delimiter = ";"
    if text.count(",") > text.count(";"):
        delimiter = ","

    csv_file = io.StringIO(text)

    reader = csv.DictReader(csv_file, delimiter=delimiter)

    headers = [h.strip().replace("\ufeff", "") for h in reader.fieldnames]

    print("Колонки CSV:", headers)

    # ищем колонку номера
    for h in headers:
        h_low = h.lower()

        if "номер" in h_low or "part" in h_low or "артикул" in h_low:
            number_key = h

        if "наимен" in h_low or "name" in h_low:
            name_key = h

    print("Колонка номера:", number_key)
    print("Колонка названия:", name_key)

    for row in reader:

        clean = {}

        for k, v in row.items():

            if not k:
                continue

            key = k.strip().replace("\ufeff", "")

            clean[key] = v.strip() if v else ""

        parts_db.append(clean)

    print(f"База загружена: {len(parts_db)} деталей")


# -------------------------
# Поиск
# -------------------------
def find_part(query):

    query = query.lower().strip()

    results = []

    for part in parts_db:

        number = str(part.get(number_key, "")).lower()
        name = str(part.get(name_key, "")).lower()

        if query in number or query in name:

            results.append(part)

        if len(results) >= 5:
            break

    if not results:
        return "❌ Деталь не найдена"

    text = "🚗 Найдено:\n\n"

    for p in results:

        number = p.get(number_key, "")
        name = p.get(name_key, "Без названия")
        price = p.get("Цена", "")
        brand = p.get("Марка", "")
        model = p.get("Модель", "")

        car = f"{brand} {model}".strip()

        text += (
            f"🔧 {name}\n"
            f"Номер: {number}\n"
            f"Авто: {car}\n"
            f"Цена: {price} ₽\n\n"
        )

    return text


# -------------------------
# Кнопка
# -------------------------
def keyboard():

    kb = telebot.types.ReplyKeyboardMarkup(resize_keyboard=True)

    kb.add("🚗 Найти запчасть")

    return kb


# -------------------------
# Старт
# -------------------------
@bot.message_handler(commands=["start"])
def start(msg):

    bot.send_message(
        msg.chat.id,
        "🚗 Бот поиска автозапчастей",
        reply_markup=keyboard()
    )


# -------------------------
# Кнопка поиска
# -------------------------
@bot.message_handler(func=lambda m: m.text == "🚗 Найти запчасть")
def ask(msg):

    bot.send_message(msg.chat.id, "Введите номер детали:")


# -------------------------
# Поиск
# -------------------------
@bot.message_handler(func=lambda m: True)
def search(msg):

    result = find_part(msg.text)

    bot.send_message(msg.chat.id, result)


# -------------------------
# Запуск
# -------------------------
if __name__ == "__main__":

    load_database()

    print("BOT STARTED")

    bot.infinity_polling()
