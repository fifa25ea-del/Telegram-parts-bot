BAD_WORDS = [
    "усилитель", "кронштейн", "крепление",
    "проводка", "абсорбер", "датчик", "провод"
]

# ===== УТИЛИТЫ =====
def split_words(text):
    return re.findall(r'\w+', text.lower())

# ===== ЗАГРУЗКА =====
def load_csv(url):
    r = requests.get(url)
    r.encoding = "cp1251"
    data = io.StringIO(r.text)
    reader = csv.DictReader(data, delimiter=";")
    return list(reader), reader.fieldnames

def load_database():
    global parts_db, wheels_db, name_key, number_key, photo_key

    parts_db, headers = load_csv(PARTS_CSV)
    wheels_db, headers2 = load_csv(WHEELS_CSV)

    for h in headers:
        h_low = h.lower()
        if "наимен" in h_low:
            name_key = h
        if "артикул" in h_low or "номер" in h_low:
            number_key = h
        if "фото" in h_low:
            photo_key = h

    print("PARTS:", len(parts_db))
    print("WHEELS:", len(wheels_db))

# ===== ПОИСК =====
def find_part(query, db):

    query = query.lower().strip()
    words = split_words(query)

    results = []

    for part in db:
        name = str(part.get(name_key, "")).lower()
        article = str(part.get(number_key, "")).lower()

        # точный артикул
        if query == article:
            return [part]

        name_words = split_words(name)

        # ВСЕ слова должны быть
        if not all(word in name_words for word in words):
            continue

        # фильтр мусора
        if any(bad in name_words for bad in BAD_WORDS):
            continue

        results.append(part)

        if len(results) >= 10:
            break

    return results

def find_smart(query, db):

    words = split_words(query)
    results = []

    for part in db:
        name = str(part.get(name_key, "")).lower()
        name_words = split_words(name)

        score = 0

        for w in words:
            if w in name_words:
                score += 2

        if any(bad in name_words for bad in BAD_WORDS):
            score -= 2

        if score > 0:
            results.append((score, part))

    results.sort(reverse=True, key=lambda x: x[0])

    return [x[1] for x in results[:10]]

def find_wheels(query, db):

    query = query.lower().replace(" ", "")
    results = []

    for part in db:
        radius = str(part.get("Диаметр диска", "")).lower()

        if query in radius or query in "r" + radius:
            results.append(part)

        if len(results) >= 10:
            break

    return results
def send_wheels_preview(chat_id, results):

    media = []

    for i, part in enumerate(results[:10]):
        photos = str(part.get("Фото", "")).split(",")

        if not photos or not photos[0]:
            continue

        caption = f"{i+1}. {part.get('Модель диска','')} \n💰 {part.get('Цена','')} ₽"

        if i == 0:
            media.append(
                telebot.types.InputMediaPhoto(photos[0], caption=caption)
            )
        else:
            media.append(
                telebot.types.InputMediaPhoto(photos[0])
            )

    if media:
        bot.send_media_group(chat_id, media)

    bot.send_message(chat_id, "👇 Листай или выбери номер")

