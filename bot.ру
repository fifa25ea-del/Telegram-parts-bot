import requests
import csv
from io import StringIO
from telegram.ext import Updater, CommandHandler, MessageHandler, Filters

TOKEN = "ВАШ_ТОКЕН_БОТА"

CSV_URL = "https://baz-on.ru/export/c592/e61a0/stuttgart-drom.csv"

parts_db = []


def load_parts():
    global parts_db

    print("Загружаю базу запчастей...")

    r = requests.get(CSV_URL)

    data = StringIO(r.text)

    reader = csv.DictReader(data)

    parts_db = []

    for row in reader:
        parts_db.append(row)

    print(f"База загружена: {len(parts_db)} деталей")


def start(update, context):
    update.message.reply_text(
        "🚗 Отправьте номер детали\n\nНапример:\nA2710106600"
    )


def search_part(number):

    number = number.lower()

    for part in parts_db:

        oem = part.get("oem", "").lower()

        if number in oem:

            name = part.get("name", "Без названия")
            price = part.get("price", "0")

            return f"""
🚗 Деталь найдена

Название: {name}
Номер: {oem}
Цена: {price} ₽
"""

    return None


def message_handler(update, context):

    text = update.message.text

    result = search_part(text)

    if result:
        update.message.reply_text(result)
    else:
        update.message.reply_text("❌ Деталь не найдена")


def main():

    load_parts()

    updater = Updater(TOKEN, use_context=True)

    dp = updater.dispatcher

    dp.add_handler(CommandHandler("start", start))
    dp.add_handler(MessageHandler(Filters.text & ~Filters.command, message_handler))

    print("BOT STARTED")

    updater.start_polling()
    updater.idle()


if __name__ == "__main__":
    main()
