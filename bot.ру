import telebot
import csv
import requests
import io

TOKEN = "8668461577:AAHisD8fV_0GqXAXoU57FXOeexTi2x1yI74"
CSV_URL = "https://baz-on.ru/export/c592/e61a0/stuttgart-drom.csv"

bot = telebot.TeleBot(TOKEN)

parts_db = []

number_key = None
name_key = None
photo_key = None

# хранение результатов поиска
user_results = {}


def load_database():

    global parts_db, number_key, name_key, photo_key

    print("Загрузка базы...")

    headers = {"User-Agent": "Mozilla/5.0"}
    r = requests.get(CSV_URL, headers=headers, timeout=30)
    r.encoding = "cp1251"

    csv_file = io.StringIO(r.text)

    reader = csv.DictReader(csv_file, delimiter=";")

    headers = reader.fieldnames

    print("Колонки CSV:", headers)

    for h in headers:

        h_low = h.lower()

        if "номер" in h_low or "артикул" in h_low:
            number_key = h

        if "наимен" in h_low:
            name_key = h

        if "фото" in h_low or "image" in h_low or "photo" in h_low:
            photo_key = h

    print("Колонка номера:", number_key)
    print("Колонка названия:", name_key)
    print("Колонка фото:", photo_key)

    parts_db.clear()

    for row in reader:
        parts_db.append(row)

    print("База загружена:", len(parts_db))


def find_part(query):

    query = query.lower().strip()

    results = []

    for part in parts_db:

        number = str(part.get(number_key, "")).lower()
        name = str(part.get(name_key, "")).lower()

        if query in number or query in name:
            results.append(part)

        if len(results) >= 20:
            break

    return results


def keyboard():

    kb = telebot.types.ReplyKeyboardMarkup(resize_keyboard=True)
    kb.add("🚗 Найти запчасть")

    return kb


@bot.message_handler(commands=["start"])
def start(msg):

    bot.send_message(
        msg.chat.id,
        "🚗 Бот поиска автозапчастей",
        reply_markup=keyboard()
    )


@bot.message_handler(func=lambda m: m.text == "🚗 Найти запчасть")
def ask(msg):

    bot.send_message(msg.chat.id, "Введите номер детали:")


@bot.message_handler(func=lambda m: True)
def search(msg):

    results = find_part(msg.text)

    if not results:
        bot.send_message(msg.chat.id, "❌ Деталь не найдена")
        return

    user_results[msg.chat.id] = results

    send_card(msg.chat.id, 0)


def send_card(chat_id, index):

    results = user_results.get(chat_id)

    if not results:
        return

    part = results[index]

    number = part.get(number_key, "")
    name = part.get(name_key, "")
    brand = part.get("Марка", "")
    model = part.get("Модель", "")
    price = part.get("Цена", "")
    status = part.get("Статус", "")
    photos = str(part.get(photo_key, "")).strip()

    text = (
        f"🔧 {name}\n"
        f"Номер: {number}\n"
        f"Авто: {brand} {model}\n"
        f"Цена: {price} ₽\n"
        f"{status}\n\n"
        f"({index+1} из {len(results)})"
    )

    kb = telebot.types.InlineKeyboardMarkup()

    kb.add(
        telebot.types.InlineKeyboardButton("⬅️", callback_data=f"prev_{index}"),
        telebot.types.InlineKeyboardButton("➡️", callback_data=f"next_{index}")
    )

    photo_list = [x.strip() for x in photos.split(",") if x.strip()]
    photo_list = photo_list[:8]

    try:

        if photo_list:

            if len(photo_list) == 1:

                bot.send_photo(
                    chat_id,
                    photo_list[0],
                    caption=text,
                    reply_markup=kb
                )

            else:

                media = []

                for i, photo_url in enumerate(photo_list):

                    if i == 0:
                        media.append(
                            telebot.types.InputMediaPhoto(
                                media=photo_url,
                                caption=text
                            )
                        )
                    else:
                        media.append(
                            telebot.types.InputMediaPhoto(photo_url)
                        )

                bot.send_media_group(chat_id, media)

                bot.send_message(chat_id, "⬅️➡️ Листайте детали", reply_markup=kb)

        else:

            bot.send_message(chat_id, text, reply_markup=kb)

    except Exception as e:

        print("Ошибка фото:", e)
        bot.send_message(chat_id, text, reply_markup=kb)


@bot.callback_query_handler(func=lambda call: True)
def callback(call):

    data = call.data
    chat_id = call.message.chat.id

    results = user_results.get(chat_id)

    if not results:
        return

    index = int(data.split("_")[1])

    if "next" in data:
        index += 1
    else:
        index -= 1

    if index < 0:
        index = len(results) - 1

    if index >= len(results):
        index = 0

    bot.delete_message(chat_id, call.message.message_id)

    send_card(chat_id, index)


if __name__ == "__main__":

    load_database()

    print("BOT STARTED")

    bot.infinity_polling()
