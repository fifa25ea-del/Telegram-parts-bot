# ===== CALLBACK =====
@bot.callback_query_handler(func=lambda call: True)
def callback(call):

    data = call.data
    chat_id = call.message.chat.id
    results = user_results.get(chat_id, [])

    # защита
    if not results:
        bot.answer_callback_query(call.id, "Нет данных")
        return

    try:
        i = int(data.split("_")[1])
    except:
        return

    if i >= len(results):
        bot.answer_callback_query(call.id, "Ошибка индекса")
        return

    item = results[i]

    # =======================
    # ❤️ ИЗБРАННОЕ
    # =======================
    if data.startswith("fav_"):
        user_id = str(chat_id)

        item_id = item.get("Артикул") or str(i)

        if user_id not in favorites:
            favorites[user_id] = []

        if item_id in favorites[user_id]:
            bot.answer_callback_query(call.id, "Уже в избранном")
        else:
            favorites[user_id].append(item_id)
            save_favorites(favorites)
            bot.answer_callback_query(call.id, "❤️ Добавлено")


    # =======================
    # ❌ УДАЛЕНИЕ
    # =======================
    if data.startswith("remove_"):
        i = int(data.split("_")[1])

        if chat_id in user_cart and len(user_cart[chat_id]) > i:
            user_cart[chat_id].pop(i)
            bot.answer_callback_query(call.id, "❌ Удалено")
        else:
            bot.answer_callback_query(call.id, "Ошибка удаления")


    # =======================
    # ⬅️ ➡️ ПЕРЕКЛЮЧЕНИЕ
    # =======================
    if data.startswith("next_") or data.startswith("prev_"):

        current = user_index.get(chat_id, 0)

        if "next" in data:
            current += 1
        else:
            current -= 1

        if current < 0:
            current = len(results) - 1
        if current >= len(results):
            current = 0

        user_index[chat_id] = current

        bot.delete_message(chat_id, call.message.message_id)
        send_card(chat_id, current)

