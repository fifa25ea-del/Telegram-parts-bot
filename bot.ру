# ===== КАРТОЧКИ =====
def send_card(chat_id, index):
    results = user_results.get(chat_id, [])
    if not results:
        return

    item = results[index]

    text = "\n".join([
        f"🔧 {item.get('Наименование', 'Без названия')}",
        f"Артикул: {item.get('Артикул', '-')}",
        f"💰 {item.get('Цена', '-')}",
        f"\n({index+1}/{len(results)})"
    ])

    photo = item.get("Фото", "")

    kb = telebot.types.InlineKeyboardMarkup()
    kb.add(
        telebot.types.InlineKeyboardButton("⬅️", callback_data=f"prev_{index}"),
        telebot.types.InlineKeyboardButton("➡️", callback_data=f"next_{index}")
    )

    try:
        if photo:
            bot.send_photo(chat_id, photo.split(",")[0], caption=text, reply_markup=kb)
        else:
            bot.send_message(chat_id, text, reply_markup=kb)
    except:
        bot.send_message(chat_id, text, reply_markup=kb)

# ===== CALLBACK =====
@bot.callback_query_handler(func=lambda call: True)
def callback(call):
    chat_id = call.message.chat.id
    results = user_results.get(chat_id, [])

    if not results:
        return

    index = user_index.get(chat_id, 0)

    if "next" in call.data:
        index += 1
    elif "prev" in call.data:
        index -= 1

    if index < 0:
        index = len(results) - 1
    if index >= len(results):
        index = 0

    user_index[chat_id] = index

    bot.delete_message(chat_id, call.message.message_id)
    send_card(chat_id, index)

