    mode = current_mode.get(msg.chat.id, "parts")

    if mode == "wheels":
        results = find_wheels(msg.text, wheels_db)

    if not results:
        bot.send_message(chat_id, "❌ Ничего не найдено")
        return

    user_results[chat_id] = results
    user_index[chat_id] = 0

    # 🔥 1. ПРЕВЬЮ (АЛЬБОМ)
    send_wheels_preview(chat_id, results)

    # 🔥 2. ПЕРВАЯ КАРТОЧКА
    send_card(chat_id, 0)
    return

# ===== КАРТОЧКА =====
def send_card(chat_id, index):

    results = user_results.get(chat_id, [])
    if not results:
        return

    part = results[index]

    name = part.get(name_key, "")
    article = part.get(number_key, "")
    price = part.get("Цена", "")
    photos = str(part.get(photo_key, "")).split(",")

    text = f"{name}\nАртикул: {article}\n💰 {price} ₽\n({index+1}/{len(results)})"

    kb = telebot.types.InlineKeyboardMarkup()
    kb.add(
        telebot.types.InlineKeyboardButton("⬅️", callback_data="prev"),
        telebot.types.InlineKeyboardButton("➡️", callback_data="next")
    )

    try:
        if photos and photos[0]:
            bot.send_photo(chat_id, photos[0], caption=text, reply_markup=kb)
        else:
            bot.send_message(chat_id, text, reply_markup=kb)
    except:
        bot.send_message(chat_id, text, reply_markup=kb)

# ===== CALLBACK =====
@bot.callback_query_handler(func=lambda call: True)
def callback(call):

    chat_id = call.message.chat.id
    results = user_results.get(chat_id, [])

    if not results:
        return

    i = user_index.get(chat_id, 0)

    if call.data == "next":
        i += 1
    elif call.data == "prev":
        i -= 1

    if i < 0:
        i = len(results) - 1
    if i >= len(results):
        i = 0

    user_index[chat_id] = i

    bot.delete_message(chat_id, call.message.message_id)
    send_card(chat_id, i)

