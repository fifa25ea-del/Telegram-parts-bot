import telebot
import csv
import requests
import io

TOKEN = "8668461577:AAE2X7UtcKhKMRAYhHG8xiowwz74p60WMiY"

PARTS_CSV = "https://baz-on.ru/export/c592/e61a0/stuttgart-drom.csv"
WHEELS_CSV = "https://baz-on.ru/export/c592/77023/drom-wheels.csv"

bot = telebot.TeleBot(TOKEN)

user_favorites = {}
user_cart = {}
user_results = {}

parts_db = []
wheels_db = []

current_mode = {}

number_key = None
name_key = None
photo_key = None


def main_menu():
    kb = telebot.types.ReplyKeyboardMarkup(resize_keyboard=True)
    kb.row("🚗 Найти запчасть")
    kb.row("🛞 Шины и диски")
    kb.row("❤️ Избранное", "🛒 Корзина")
    return kb


def load_csv(url):
    headers = {"User-Agent": "Mozilla/5.0"}
    r = requests.get(url, headers=headers, timeout=30)
    r.encoding = "cp1251"

    csv_file = io.StringIO(r.text)
    reader = csv.DictReader(csv_file, delimiter=";")

    return list(reader), reader.fieldnames


def load_database():
    global parts_db, wheels_db, number_key, name_key, photo_key

    parts_db, headers = load_csv(PARTS_CSV)
    wheels_db, _ = load_csv(WHEELS_CSV)

    for h in headers:
        h_low = h.lower()

        if "номер" in h_low or "артикул" in h_low:
            number_key = h

        if "наимен" in h_low:
            name_key = h

        if "фото" in h_low:
            photo_key = h


def find_part(query, db):
    query = query.lower()
    results = []

    for part in db:
        if query in str(part).lower():
            results.append(part)

        if len(results) >= 20:
            break

    return results


@bot.message_handler(commands=["start"])
def start(message):
    bot.send_message(message.chat.id, "Выберите действие:", reply_markup=main_menu())


@bot.message_handler(func=lambda m: m.text == "🚗 Найти запчасть")
def parts_mode(msg):
    current_mode[msg.chat.id] = "parts"
    bot.send_message(msg.chat.id, "Введите номер детали:")


@bot.message_handler(func=lambda m: m.text == "🛞 Шины и диски")
def wheels_mode(msg):
    current_mode[msg.chat.id] = "wheels"
    bot.send_message(msg.chat.id, "Введите размер (например r18):")


@bot.message_handler(func=lambda m: m.text and len(m.text) > 2 and not m.text.startswith(("🚗","🛞","🛒","❤️")))
def search(msg):

    mode = current_mode.get(msg.chat.id, "parts")

    db = parts_db if mode == "parts" else wheels_db

    results = find_part(msg.text, db)

    if not results:
        bot.send_message(msg.chat.id, "❌ Ничего не найдено")
        return

    user_results[msg.chat.id] = results
    send_card(msg.chat.id, 0)


def send_card(chat_id, index):
    results = user_results.get(chat_id, [])
    part = results[index]

    name = part.get(name_key, "Нет")
    article = part.get("Артикул", "")
    number = part.get(number_key, "")
    price = part.get("Цена", "")
    photos = str(part.get(photo_key, ""))

    text = f"{name}\nАртикул: {article}\nНомер: {number}\nЦена: {price} ₽\n({index+1}/{len(results)})"

    kb = telebot.types.InlineKeyboardMarkup()
    kb.add(
        telebot.types.InlineKeyboardButton("⬅️", callback_data=f"prev_{index}"),
        telebot.types.InlineKeyboardButton("➡️", callback_data=f"next_{index}")
    )
    kb.add(
        telebot.types.InlineKeyboardButton("❤️", callback_data=f"fav_{index}"),
        telebot.types.InlineKeyboardButton("🛒", callback_data=f"cart_{index}")
    )

    if photos:
        photo = photos.split(",")[0].strip()
        bot.send_photo(chat_id, photo, caption=text, reply_markup=kb)
    else:
        bot.send_message(chat_id, text, reply_markup=kb)


@bot.callback_query_handler(func=lambda call: True)
def callback(call):
    data = call.data
    chat_id = call.message.chat.id
    results = user_results.get(chat_id, [])

    if data.startswith("fav_"):
        i = int(data.split("_")[1])
        user_favorites.setdefault(chat_id, []).append(results[i])
        bot.answer_callback_query(call.id, "Добавлено ❤️")
        return

    if data.startswith("cart_"):
        i = int(data.split("_")[1])
        user_cart.setdefault(chat_id, []).append(results[i])
        bot.answer_callback_query(call.id, "Добавлено 🛒")
        return

    if data.startswith("next_") or data.startswith("prev_"):
        i = int(data.split("_")[1])
        i = i + 1 if "next" in data else i - 1

        if i < 0: i = len(results)-1
        if i >= len(results): i = 0

        bot.delete_message(chat_id, call.message.message_id)
        send_card(chat_id, i)


if __name__ == "__main__":
    print("STARTING BOT...")
    
    try:
        load_database()
        print("DATABASE LOADED")

        bot.infinity_polling()
    except Exception as e:
        print("ERROR:", e)
