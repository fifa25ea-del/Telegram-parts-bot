def load_database():

    global parts_db, number_key, name_key, photo_key

    print("Загрузка базы...")

    r = requests.get(CSV_URL)
    r.encoding = "cp1251"

    csv_file = io.StringIO(r.text)

    reader = csv.DictReader(csv_file, delimiter=";")

    headers = reader.fieldnames

    print("Колонки CSV:", headers)

    for h in headers:

        h_low = h.lower()

        if "номер" in h_low:
            number_key = h

        if "наимен" in h_low:
            name_key = h

        if "фото" in h_low:
            photo_key = h

    parts_db.clear()

    for row in reader:
        parts_db.append(row)

    print("База загружена:", len(parts_db))


def find_part(query):

    query = query.lower().strip()

    results = []

    for part in parts_db:

        number = str(part.get(number_key, "")).lower()
        name = str(part.get(name_key, "")).lower()

        if query in number or query in name:
            results.append(part)

    return results


