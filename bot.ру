def parse_filters(query):
    query = query.lower()

    filters = {
        "position": None,  # перед / зад
        "side": None       # левый / правый
    }

    if "перед" in query:
        filters["position"] = "перед"

    elif "зад" in query:
        filters["position"] = "зад"

    if "лев" in query:
        filters["side"] = "лев"

    elif "прав" in query:
        filters["side"] = "прав"

    return filters

def detect_part_type(text):
    for t in PART_TYPES:
        if t in text:
            return t
    return None

