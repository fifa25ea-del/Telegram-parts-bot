# поиск по номеру
@bot.message_handler(func=lambda m: m.text == "🔎 Поиск по номеру")
def search_number(msg):
    m = bot.send_message(msg.chat.id, "Введите оригинальный номер:")
    bot.register_next_step_handler(m, find_number)


def find_number(msg):

    number = msg.text.lower()

    results = [x for x in data if number in str(x["Номер"]).lower()]

    if not results:
        bot.send_message(msg.chat.id, "❌ Ничего не найдено")
        return

    for item in results[:5]:
        send_item(msg.chat.id, item)


# поиск по названию
@bot.message_handler(func=lambda m: m.text == "📝 Поиск по наименованию")
def search_name(msg):
    m = bot.send_message(msg.chat.id, "Введите название детали:")
    bot.register_next_step_handler(m, find_name)


def find_name(msg):

    name = msg.text.lower()

    results = [x for x in data if name in str(x["Наименование"]).lower()]

    if not results:
        bot.send_message(msg.chat.id, "❌ Ничего не найдено")
        return

    for item in results[:5]:
        send_item(msg.chat.id, item)


# карточка товара
def send_item(chat_id, item):

    text = f"""
<b>{item['Наименование']}</b>

Артикул: <b>{item['Артикул']}</b>
Марка: {item['Марка']}
Модель: {item['Модель']}
Год: {item['Год']}

Оригинальный номер: {item['Номер']}

Цена: <b>{item['Цена']} ₽</b>
Состояние: {item['Новый/БУ']}
"""

    kb = types.InlineKeyboardMarkup()

    buy = types.InlineKeyboardButton(
        "🛒 Купить",
        url="https://t.me/ВАШ_МЕНЕДЖЕР"
    )

    manager = types.InlineKeyboardButton(
        "💬 Менеджер",
        url="https://t.me/ВАШ_МЕНЕДЖЕР"
    )

    kb.add(buy, manager)

    photos = item["Фото"]

    if photos:

        photo_list = [x.strip() for x in photos.split(",") if x.strip()]
        photo_list = photo_list[:8]

        try:

            media = []

            for i, url in enumerate(photo_list):

                r = requests.get(url)

                if r.status_code != 200:
                    continue

                image = io.BytesIO(r.content)
                image.name = "photo.jpg"

                if i == 0:
                    media.append(
                        types.InputMediaPhoto(
                            image,
                            caption=text,
                            parse_mode="HTML"
                        )
                    )
                else:
                    media.append(types.InputMediaPhoto(image))

            if len(media) == 1:

                bot.send_photo(
                    chat_id,
                    media[0].media,
                    caption=text,
                    parse_mode="HTML",
                    reply_markup=kb
                )

            else:

                bot.send_media_group(chat_id, media)

                bot.send_message(
                    chat_id,
                    "⬇️ Управление",
                    reply_markup=kb
                )

        except:

            bot.send_message(
                chat_id,
                text,
                parse_mode="HTML",
                reply_markup=kb
            )

    else:

        bot.send_message(
            chat_id,
            text,
            parse_mode="HTML",
            reply_markup=kb
)


