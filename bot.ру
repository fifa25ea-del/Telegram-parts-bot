import telebot
import requests
import csv
from io import StringIO
from telebot import types

TOKEN = "8668461577:AAHisD8fV_0GqXAXoU57FXOeexTi2x1yI74"
CSV_URL = "https://baz-on.ru/export/c592/e61a0/stuttgart-drom.csv"

bot = telebot.TeleBot(TOKEN)

parts_db = []


# Загрузка базы
def load_database():

    global parts_db

    print("Загрузка базы...")

    r = requests.get(CSV_URL)

    csv_data = StringIO(r.text)

    reader = csv.DictReader(csv_data)

    parts_db = []

    for row in reader:

        clean_row = {}

        for key, value in row.items():

            if key is None:
                continue

            clean_key = key.strip().replace("\ufeff", "")

            clean_row[clean_key] = value

        parts_db.append(clean_row)

    print(f"База загружена: {len(parts_db)} деталей")
# Поиск детали
def search_part(number):

    number = number.strip().lower()

    results = []

    for part in parts_db:

        row_text = str(part).lower()

        if number in row_text:

            results.append(part)

        if len(results) >= 5:
            break

    return results


# Старт
@bot.message_handler(commands=["start"])
def start(message):

    markup = types.ReplyKeyboardMarkup(resize_keyboard=True)

    btn = types.KeyboardButton("🚗 Найти запчасть")

    markup.add(btn)

    bot.send_message(
        message.chat.id,
        "Добро пожаловать!\n\nНажмите кнопку для поиска детали.",
        reply_markup=markup
    )


# Кнопка поиска
@bot.message_handler(func=lambda message: message.text == "🚗 Найти запчасть")
def ask_number(message):

    msg = bot.send_message(message.chat.id, "Введите номер детали:")

    bot.register_next_step_handler(msg, find_part)


# Поиск
def find_part(message):

    number = message.text

    results = search_part(number)

    if not results:

        bot.send_message(message.chat.id, "❌ Деталь не найдена")
        return

    text = "🚗 Найдено:\n\n"

    for part in results:

        name = part.get("Наименование", "Без названия")
        article = part.get("Артикул", "")
        brand = part.get("Марка", "")
        model = part.get("Модель", "")
        price = part.get("Цена", "0")

        text += f"""
Название: {name}
Артикул: {article}
Авто: {brand} {model}
Цена: {price} ₽

"""

    bot.send_message(message.chat.id, text)


# Запуск
load_database()

print("BOT STARTED")

bot.infinity_polling()
