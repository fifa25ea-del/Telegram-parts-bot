@bot.message_handler(func=lambda m: m.text == "🛒 Корзина")
def show_cart(message):

    items = user_cart.get(message.chat.id, [])

    if not items:
        bot.send_message(message.chat.id, "❌ Корзина пустая")
        return

    total = 0

    for i, part in enumerate(items):
        try:
            price = int(part.get("Цена", 0))
        except:
            price = 0

        total += price

        kb = telebot.types.InlineKeyboardMarkup()
        kb.add(
            telebot.types.InlineKeyboardButton(
                "❌ Удалить",
                callback_data=f"remove_{i}"
            )
        )

        bot.send_message(
            message.chat.id,
            f"{part.get(name_key)}\n💰 {price} ₽",
            reply_markup=kb
        )

        bot.send_message(
            message.chat.id,
            f"{part.get(name_key) or 'Без названия'}\n💰 {part.get('Цена')} ₽"
        )


# ===== CALLBACK =====
@bot.callback_query_handler(func=lambda call: True)
def callback(call):

    data = call.data
    chat_id = call.message.chat.id
    results = user_results.get(chat_id, [])

    # защита
    if not results:
        bot.answer_callback_query(call.id, "Нет данных")
        return

    try:
        i = int(data.split("_")[1])
    except:
        return

    if i >= len(results):
        bot.answer_callback_query(call.id, "Ошибка индекса")
        return

    item = results[i]

    # =======================
    # ❤️ ИЗБРАННОЕ
    # =======================
    if data.startswith("fav_"):
        user_favorites.setdefault(chat_id, [])

        if item not in user_favorites[chat_id]:
            user_favorites[chat_id].append(item)
            bot.answer_callback_query(call.id, "❤️ Добавлено")
        else:
            bot.answer_callback_query(call.id, "Уже есть")

        return


    # =======================
    # ❌ УДАЛЕНИЕ
    # =======================
    if data.startswith("remove_"):
        i = int(data.split("_")[1])

        if chat_id in user_cart and len(user_cart[chat_id]) > i:
            user_cart[chat_id].pop(i)
            bot.answer_callback_query(call.id, "❌ Удалено")
        else:
            bot.answer_callback_query(call.id, "Ошибка удаления")

        return

    # =======================
    # ⬅️ ➡️ ПЕРЕКЛЮЧЕНИЕ
    # =======================
    if data.startswith("next_") or data.startswith("prev_"):

        current = user_index.get(chat_id, 0)

        if "next" in data:
            current += 1
        else:
            current -= 1

        if current < 0:
            current = len(results) - 1
        if current >= len(results):
            current = 0

        user_index[chat_id] = current

        bot.delete_message(chat_id, call.message.message_id)
        send_card(chat_id, current)
