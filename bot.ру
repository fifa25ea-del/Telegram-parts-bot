# ===== ЗАГРУЗКА CSV =====
def load_csv(url):
    headers = {"User-Agent": "Mozilla/5.0"}
    r = requests.get(url, headers=headers, timeout=30)
    r.encoding = "cp1251"

    csv_file = io.StringIO(r.text)
    reader = csv.DictReader(csv_file, delimiter=";")

    return list(reader), reader.fieldnames

def load_database():
    global parts_db, wheels_db, number_key, name_key, photo_key

    parts_db, headers = load_csv(PARTS_CSV)
    wheels_db, headers2 = load_csv(WHEELS_CSV)

    for h in headers:
        h_low = h.lower()

        if "артикул" in h_low or "номер" in h_low:
            number_key = h

        if "наимен" in h_low or "название" in h_low:
            name_key = h

        if "фото" in h_low or "image" in h_low:
            photo_key = h

def find_wheels(query, db):

    query = query.lower().replace(" ", "")
    results = []

    for part in db:
        radius = str(part.get("Диаметр диска", "")).lower()

        if not radius:
            continue

        # ищем r18 или 18
        if query in radius or query in f"r{radius}":
            results.append(part)

        if len(results) >= 20:
            break

    return results
# ===== ПОИСК =====
def find_part(query, db):

    query_words = split_words(query)
    results = []

    for part in db:
        name = str(part.get(name_key, "")).lower()
        words = split_words(name)

        # 🔥 ЕСЛИ ОДНО СЛОВО → СТРОГОЕ СОВПАДЕНИЕ
        if len(query_words) == 1:
            if query_words[0] in words:
                
                # ❌ исключаем "усилитель бампера" и т.д.
                if len(words) > 2:
                    continue

                results.append(part)

        # 🔥 ЕСЛИ НЕСКОЛЬКО СЛОВ
        else:
            if all(q in words for q in query_words):
                results.append(part)

        if len(results) >= 20:
            break

    return results

