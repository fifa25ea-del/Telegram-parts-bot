bot = telebot.TeleBot(TOKEN)

parts_db = []


# -------------------------
# Загрузка базы CSV
# -------------------------
def load_database():
    global parts_db

    print("Загрузка базы...")

    r = requests.get(CSV_URL)
    r.encoding = "utf-8"

    text = r.text

    # автоопределение разделителя
    delimiter = ";"
    if text.count(",") > text.count(";"):
        delimiter = ","

    csv_file = io.StringIO(text)

    reader = csv.DictReader(csv_file, delimiter=delimiter)

    parts_db = []

    for row in reader:
        clean = {}

        for k, v in row.items():
            if k:
                key = k.strip().replace("\ufeff", "")
                clean[key] = v.strip() if v else ""

        parts_db.append(clean)

    print(f"База загружена: {len(parts_db)} деталей")


# -------------------------
# Поиск
# -------------------------
def find_part(query):

    query = query.lower().strip()

    results = []

    for part in parts_db:

        number = str(part.get("Номер", "")).lower()
        name = str(part.get("Наименование", "")).lower()

        if query in number or query in name:

            results.append(part)

        if len(results) >= 5:
            break

    if not results:
        return "❌ Деталь не найдена"

    text = "🚗 Найдено:\n\n"

    for p in results:

        name = p.get("Наименование", "Без названия")
        number = p.get("Номер", "")
        brand = p.get("Марка", "")
        model = p.get("Модель", "")
        price = p.get("Цена", "")
        status = p.get("Статус", "")

        car = f"{brand} {model}".strip()

        text += (
            f"🔧 {name}\n"
            f"Номер: {number}\n"
            f"Авто: {car}\n"
            f"Цена: {price} ₽\n"
            f"{status}\n\n"
        )

    return text


