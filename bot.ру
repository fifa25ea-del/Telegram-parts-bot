import os
import requests
import xml.etree.ElementTree as ET

from telegram import ReplyKeyboardMarkup
from telegram.ext import Updater, CommandHandler, MessageHandler, Filters

TOKEN = os.getenv("TOKEN")

XML_URL = "https://baz-on.ru/export/c592/ca617/drom-140001-parts.xml"

parts_db = []


def load_parts():

    print("Загружаю базу запчастей...")

    r = requests.get(XML_URL)

    root = ET.fromstring(r.content)

    for part in root.findall(".//part"):

        number = part.find("manufactureNumber")
        name = part.find("title")
        price = part.find("price")

        if number is not None:

            parts_db.append({
                "number": number.text if number is not None else "",
                "name": name.text if name is not None else "",
                "price": price.text if price is not None else ""
            })

    print("База загружена:", len(parts_db), "деталей")
def search_part(number):

    for part in parts_db:

        if number.lower() in part["number"].lower():

            return f"""
🚗 Деталь найдена

Название: {part["name"]}
Номер: {part["number"]}
Цена: {part["price"]} ₽
"""

    return None


def start(update, context):

    keyboard = [
        ["🚗 Найти запчасть"],
        ["📦 Сделать заказ"],
        ["📞 Связаться"]
    ]

    reply_markup = ReplyKeyboardMarkup(keyboard, resize_keyboard=True)

    update.message.reply_text(
        "Добро пожаловать 🚗\nВыберите действие:",
        reply_markup=reply_markup
    )


def handle_message(update, context):

    text = update.message.text

    if text == "🚗 Найти запчасть":

        update.message.reply_text("Напишите номер детали")

    elif text == "📦 Сделать заказ":

        update.message.reply_text(
            "Напишите:\nМарка авто\nГод\nКакая деталь нужна"
        )

    elif text == "📞 Связаться":

        update.message.reply_text(
            "Менеджер: @your_username"
        )

    else:

        update.message.reply_text("🔎 Ищу деталь...")

        result = search_part(text)

        if result:
            update.message.reply_text(result)
        else:
            update.message.reply_text("❌ Деталь не найдена")


def main():

    load_parts()

    updater = Updater(TOKEN, use_context=True)

    dp = updater.dispatcher

    dp.add_handler(CommandHandler("start", start))
    dp.add_handler(MessageHandler(Filters.text, handle_message))

    print("BOT STARTED")

    updater.start_polling()
    updater.idle()


if __name__ == "__main__":
    main()
