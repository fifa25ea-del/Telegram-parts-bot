import os
from telegram import ReplyKeyboardMarkup
from telegram.ext import Updater, CommandHandler, MessageHandler, Filters
import requests
import xml.etree.ElementTree as ET

XML_URL = "https://baz-on.ru/export/c592/ca617/drom-140001-parts.xml"


def search_part(number):
    r = requests.get(XML_URL)

    if r.status_code != 200:
        return None

    root = ET.fromstring(r.content)

    for item in root.findall(".//item"):

        part_number = item.find("oem")
        name = item.find("name")
        price = item.find("price")

        if part_number is not None and number.lower() in part_number.text.lower():

            return f"""
🚗 Деталь найдена

Название: {name.text}
Номер: {part_number.text}
Цена: {price.text} ₽
"""

    return None

TOKEN = os.getenv("TOKEN")

def start(update, context):
    keyboard = [
        ["🚗 Найти запчасть"],
        ["📦 Сделать заказ"],
        ["📞 Связаться"]
    ]

    reply_markup = ReplyKeyboardMarkup(keyboard, resize_keyboard=True)

    update.message.reply_text(
        "Добро пожаловать 🚗\nВыберите действие:",
        reply_markup=reply_markup
    )

def handle_message(update, context):
    text = update.message.text

    if text == "🚗 Найти запчасть":
        update.message.reply_text("Напишите номер или название детали")

    elif text == "📦 Сделать заказ":
        update.message.reply_text("Напишите:\nМарка авто\nГод\nКакая деталь нужна")

    elif text == "📞 Связаться":
        update.message.reply_text("Менеджер: @your_username")

def main():
    updater = Updater(TOKEN, use_context=True)
    dp = updater.dispatcher

    dp.add_handler(CommandHandler("start", start))
    dp.add_handler(MessageHandler(Filters.text, handle_message))

    print("BOT STARTED")

    updater.start_polling()
    updater.idle()

if __name__ == "__main__":
    main()
