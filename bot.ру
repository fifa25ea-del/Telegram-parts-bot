import telebot
import requests
import xml.etree.ElementTree as ET

TOKEN = "8696046662:AAE9MOoNU_yU4B_itc-g24wWLLD_R0yvNgk"
XML_URL = "https://baz-on.ru/export/c592/ca617/drom-140001-parts.xml"

bot = telebot.TeleBot(TOKEN)

def load_parts():
    r = requests.get(XML_URL)
    root = ET.fromstring(r.content)

    parts = []

    for part in root.findall("part"):

        title = part.findtext("title")
        number = part.findtext("manufactureNumber")
        price = part.findtext("priceWithDiscount")

        parts.append({
            "title": title,
            "number": number,
            "price": price
        })

    return parts

parts = load_parts()

@bot.message_handler(func=lambda m: True)
def search(message):

    query = message.text.lower()

    for p in parts:

        if p["number"] and query in p["number"].lower():

            bot.send_message(
                message.chat.id,
                f"{p['title']}\n"
                f"Номер: {p['number']}\n"
                f"Цена: {p['price']}"
            )
            return

    bot.send_message(message.chat.id, "Ничего не найдено")

bot.infinity_polling()
