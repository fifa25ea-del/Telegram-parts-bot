@bot.message_handler(func=lambda m: m.text and "Избранное" in m.text)
def show_favorites(message):

    chat_id = message.chat.id
    items = user_favorites.get(chat_id, [])

    if not items:
        bot.send_message(chat_id, "❌ Избранное пусто")
        return

    for part in items:

        name = part.get(name_key) or part.get("Наименование") or "Без названия"
        article = part.get("Артикул", "Нет артикула")
        number = part.get("Номер", "Нет номера")
        price = part.get("Цена", "0")
        photo = part.get(photo_key) or part.get("Фото")

        if photo:
            photos = photo.split(",")
            photo = photos[0].strip()

        text = (
            f"❤️ {name}\n"
            f"🔢 Артикул: {article}\n"
            f"🆔 Номер: {number}\n"
            f"💰 Цена: {price} ₽"
        )

        if photo:
            bot.send_photo(chat_id, photo, caption=text)
        else:
            bot.send_message(chat_id, text)

