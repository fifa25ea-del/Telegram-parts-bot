def find_part(query, db):
    query = query.lower()
    words = query.split()

    main = words[0]

    results = []

    for part in db:
        name = str(part.get(name_key, "")).lower()

        # 🔥 РАЗБИВАЕМ СТРОКУ В СЛОВА
        name_words = re.findall(r"\w+", name)

        # 💣 "бампер" должен быть ОТДЕЛЬНЫМ словом
        if main not in name_words:
            continue

        # 💣 И ГЛАВНОЕ: он должен быть БЛИЖЕ К НАЧАЛУ
