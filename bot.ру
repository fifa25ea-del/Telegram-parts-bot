@bot.message_handler(commands=["admin"])
def admin_panel(message):
    if message.from_user.id != ADMIN_ID:
        return

    total_users = len(stats)

    total_searches = sum(u["searches"] for u in stats.values())
    total_views = sum(u["views"] for u in stats.values())
    total_fav = sum(u["favorites"] for u in stats.values())

    text = (
        f"📊 Статистика бота:\n\n"
        f"👥 Пользователей: {total_users}\n"
        f"🔍 Поисков: {total_searches}\n"
        f"👁 Просмотров: {total_views}\n"
        f"❤️ Добавлений в избранное: {total_fav}"
    )

    bot.send_message(message.chat.id, text)

@bot.message_handler(commands=["top"])
def top_users(message):
    if message.from_user.id != ADMIN_ID:
        return

    top = sorted(stats.items(), key=lambda x: x[1]["views"], reverse=True)[:5]

    text = "🏆 Топ пользователей:\n\n"

    for user_id, data in top:
        text += f"ID: {user_id}\n👁 {data['views']} просмотров\n\n"

    bot.send_message(message.chat.id, text)

@bot.message_handler(func=lambda message: True)
def handle_text(message):
    chat_id = message.chat.id
    text = message.text

    print("TEXT:", text)

    mode = current_mode.get(chat_id)
    print("MODE:", mode)

    # 🔥 ЛОГ ТОЛЬКО ДЛЯ PARTS
    if mode == "parts" and not text.startswith("/") and len(text) > 3:
        log_search(chat_id, text, "parts")

        results = find_part(text, parts_db)

        if not results:
            bot.send_message(chat_id, "❌ Ничего не найдено")
            return

        user_results[chat_id] = results
        send_part_card(chat_id, 0)
        return

    # ===== КНОПКИ =====
    if text == "🚗 Найти запчасть":
        current_mode[chat_id] = "parts"
        bot.send_message(chat_id, "🔎 Введите номер детали")
        return

    if text == "🛞 Шины и диски":
        current_mode[chat_id] = "wheels"
        bot.send_message(chat_id, "🔎 Введите параметры (например R18)")
        return

    if text == "🚘 В разборе":
        current_mode[chat_id] = "donors"
        user_results[chat_id] = donors_db[:20]
        user_index[chat_id] = 0
        user_photo_index[chat_id] = 0

        send_donor_card(chat_id, 0)
        return

    # ===== ПОИСК =====
    mode = current_mode.get(chat_id)

    if mode == "parts":
        log_search(chat_id, text, "parts")
        results = find_part(text, parts_db)

        if not results:
            bot.send_message(chat_id, "❌ Ничего не найдено")
            return

        user_results[chat_id] = results
        user_index[chat_id] = 0
        user_photo_index[chat_id] = 0

        send_part_card(chat_id, 0)
        return

    elif mode == "wheels":
        log_search(chat_id, text, "wheels")
        results = find_wheels(text, wheels_db)

        if not results:
            bot.send_message(chat_id, "❌ Ничего не найдено")
            return

        user_results[chat_id] = results
        user_index[chat_id] = 0

        send_wheel_card(chat_id, 0)
        return

    bot.send_message(chat_id, "Выберите действие из меню", reply_markup=main_menu())

