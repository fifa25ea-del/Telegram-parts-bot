def send_card(chat_id, index):

    mode = current_mode.get(chat_id, "parts")

    if mode == "wheels":
        send_wheel_card(chat_id, index)
    else:
        send_part_card(chat_id, index)
def send_part_card(chat_id, index):

    results = user_results.get(chat_id, [])
    part = results[index]

    name = part.get(name_key, "")
    article = part.get("Артикул", "")
    number = part.get("Номер", "")
    brand = part.get("Марка", "")
    model = part.get("Модель", "")
    price = part.get("Цена", "")
    photos = str(part.get(photo_key, "")).strip()

    text = (
        f"🔧 {name}\n"
        f"Артикул: {article}\n"
        f"Номер: {number}\n"
        f"{brand} {model}\n"
        f"💰 {price} ₽\n\n"
        f"({index+1}/{len(results)})"
    )

    send_with_photo(chat_id, text, photos, index)

def send_wheel_card(chat_id, index):

    results = user_results.get(chat_id, [])
    if not results:
        return

    part = results[index]

    brand = part.get("Производитель диска", "")
    model = part.get("Модель диска", "")
    article = part.get("Артикул", "")
    price = part.get("Цена", "")
    photos = str(part.get("Фото", "")).strip()

    radius = part.get("Диаметр диска", "")
    width = part.get("Ширина диска", "")
    et = part.get("Вылет диска", "")
    pcd = part.get("PCD диска", "")
    dia = part.get("Диаметр осевого отверстия диска", "")

    text = (
        f"🛞 {brand} {model}\n\n"
        f"Артикул: {article}\n"
        f"💰 {price} ₽\n\n"
        f"📏 R{radius or '-'} | {width or '-'}J | ET{et or '-'}\n"
        f"🔩 PCD: {pcd or '-'}\n"
        f"🕳 DIA: {dia or '-'}\n\n"
        f"({index+1}/{len(results)})"
    )

    send_with_photo(chat_id, text, photos, index)

def send_with_photo(chat_id, text, photos, index):

    kb = telebot.types.InlineKeyboardMarkup(row_width=2)

    kb.add(
        telebot.types.InlineKeyboardButton("⬅️ Назад", callback_data=f"prev_{index}"),
        telebot.types.InlineKeyboardButton("➡️ Вперед", callback_data=f"next_{index}")
    )

    kb.add(
        telebot.types.InlineKeyboardButton("❤️ Сохранить", callback_data=f"fav_{index}"),
        telebot.types.InlineKeyboardButton("💬 Связаться", url="https://t.me/Stuttgart_mercedes")
    )

    try:
        if photos:
            photo_list = [x.strip() for x in photos.split(",") if x.strip()]

            if len(photo_list) > 1:
                media = []

                for i, url in enumerate(photo_list[:8]):
                    if i == 0:
                        media.append(
                            telebot.types.InputMediaPhoto(url, caption=text)
                        )
                    else:
                        media.append(
                            telebot.types.InputMediaPhoto(url)
                        )

                bot.send_media_group(chat_id, media)
                bot.send_message(chat_id, "⬇️ Действия:", reply_markup=kb)
            else:
                bot.send_photo(chat_id, photo_list[0], caption=text, reply_markup=kb)
        else:
            bot.send_message(chat_id, text, reply_markup=kb)

    except Exception as e:
        print("Ошибка фото:", e)
        bot.send_message(chat_id, text, reply_markup=kb)

