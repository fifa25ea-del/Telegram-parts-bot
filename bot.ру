def load_data():

    print("Загрузка базы...")

    r = requests.get(CSV_URL)
    r.encoding = "cp1251"

    csv_file = io.StringIO(r.text)

    reader = csv.DictReader(csv_file, delimiter=";")

    data = list(reader)

    print("Загружено товаров:", len(data))

    return data


