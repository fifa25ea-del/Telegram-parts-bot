import requests
import csv
from io import StringIO
from telegram import Update, ReplyKeyboardMarkup
from telegram.ext import Updater, CommandHandler, MessageHandler, Filters, CallbackContext

TOKEN = "8668461577:AAHisD8fV_0GqXAXoU57FXOeexTi2x1yI74"
CSV_URL = "https://baz-on.ru/export/c592/e61a0/stuttgart-drom.csv"

parts_db = []
waiting_number = {}

# загрузка базы
def load_database():

    global parts_db

    r = requests.get(CSV_URL)

    if r.status_code != 200:
        print("Ошибка загрузки базы")
        return

    csv_data = StringIO(r.text)
    reader = csv.DictReader(csv_data)
    print(reader.fieldnames)
    parts_db = list(reader)

    print(f"База загружена: {len(parts_db)} деталей")


# поиск детали
def search_part(number):

    number = number.strip().lower()

    for part in parts_db:

        article = str(part.get("Артикул", "")).strip().lower()
        number_field = str(part.get("Номер", "")).strip().lower()

        if number == article or number == number_field:

            name = part.get("Наименование", "Без названия")
            price = part.get("Цена", "0")
            brand = part.get("Марка", "")
            model = part.get("Модель", "")
            article_real = part.get("Артикул", "")

            return f"""
🚗 Деталь найдена

Название: {name}
Артикул: {article_real}
Авто: {brand} {model}
Цена: {price} ₽
"""

    return None


# старт
def start(update: Update, context: CallbackContext):

    keyboard = [["🚗 Найти запчасть"]]

    reply_markup = ReplyKeyboardMarkup(keyboard, resize_keyboard=True)

    update.message.reply_text(
        "Добро пожаловать.\nНажмите кнопку чтобы найти деталь.",
        reply_markup=reply_markup
    )


# обработка сообщений
def message_handler(update: Update, context: CallbackContext):

    chat_id = update.message.chat_id
    text = update.message.text

    if text == "🚗 Найти запчасть":

        waiting_number[chat_id] = True
        update.message.reply_text("Введите номер детали:")
        return

    if waiting_number.get(chat_id):

        result = search_part(text)

        if result:
            update.message.reply_text(result)
        else:
            update.message.reply_text("❌ Деталь не найдена")

        waiting_number[chat_id] = False
        return


def main():

    load_database()

    updater = Updater(TOKEN, use_context=True)

    dp = updater.dispatcher

    dp.add_handler(CommandHandler("start", start))
    dp.add_handler(MessageHandler(Filters.text, message_handler))

    updater.start_polling()

    print("BOT STARTED")

    updater.idle()


if __name__ == "__main__":
    main()
