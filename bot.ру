    text = f"{name}\nАртикул: {article}\nНомер: {number}\nЦена: {price} ₽\n({index+1}/{len(results)})"

    kb = telebot.types.InlineKeyboardMarkup()
    kb.add(
        telebot.types.InlineKeyboardButton("⬅️", callback_data=f"prev_{index}"),
        telebot.types.InlineKeyboardButton("➡️", callback_data=f"next_{index}")
    )
