# -----------------------------
# Поиск
# -----------------------------

@bot.message_handler(func=lambda m: True)
def search(msg):

    text = msg.text.strip()

    # игнор кнопок
    if text in ["📦 Как искать", "📞 Менеджер", "🌐 Наш сайт"]:
        return

    results = find_part(text)

    if not results:

        bot.send_message(
            msg.chat.id,
            "❌ Деталь не найдена"
        )
        return

    user_results[msg.chat.id] = {
        "results": results,
        "index": 0
    }

    send_part(
        msg.chat.id,
        results[0],
        0,
        len(results)
    )


