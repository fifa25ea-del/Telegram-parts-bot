@bot.callback_query_handler(func=lambda call: call.data.startswith("removefav_"))
def remove_favorite(call):
        user_id = str(call.from_user.id)

        _, item_id = call.data.split("_")

        if user_id in favorites and item_id in favorites[user_id]:
            favorites[user_id].remove(item_id)
            save_favorites(favorites)

        bot.answer_callback_query(call.id, "❌ Удалено")
        bot.delete_message(call.message.chat.id, call.message.message_id)



@bot.callback_query_handler(func=lambda call: True)
def callback(call):

    data = call.data
    chat_id = call.message.chat.id
    results = user_results.get(chat_id, [])

    if not results:
        bot.answer_callback_query(call.id, "Нет данных")
        return

    # =======================
    # ❤️ ИЗБРАННОЕ
    # =======================
    if data.startswith("fav_"):
        i = int(data.split("_")[1])

        if i >= len(results):
            return

        item = results[i]
        user_id = str(chat_id)

        item_id = item.get("Артикул") or str(i)

        if user_id not in favorites:
            favorites[user_id] = []

        if item_id in favorites[user_id]:
            bot.answer_callback_query(call.id, "Уже в избранном")
        else:
            favorites[user_id].append(item_id)
            save_favorites(favorites)
            bot.answer_callback_query(call.id, "❤️ Добавлено")

        return

    # =======================
    # ⬅️ ➡️ ПЕРЕКЛЮЧЕНИЕ
    # =======================
    if data.startswith("next_") or data.startswith("prev_"):

    current = user_index.get(chat_id, 0)

    if "next" in data:
        current += 1
    else:
        current -= 1

    if current < 0:
        current = len(results) - 1
    if current >= len(results):
        current = 0

    user_index[chat_id] = current

    part = results[current]

    mode = current_mode.get(chat_id, "parts")

    if mode == "wheels":
        photos = str(part.get("Фото", ""))
        photo_list = [x.strip() for x in photos.split(",") if x.strip()]

        main_photo = photo_list[0] if photo_list else None

        text = (
            f"🛞 {part.get('Производитель диска','')} {part.get('Модель диска','')}\n\n"
            f"Артикул: {part.get('Артикул','')}\n"
            f"💰 {part.get('Цена','')} ₽\n\n"
            f"📏 R{part.get('Диаметр диска','-')} | {part.get('Ширина диска','-')}J | ET{part.get('Вылет диска','-')}\n"
            f"🔩 PCD: {part.get('PCD диска','-')}\n"
            f"🕳 DIA: {part.get('Диаметр осевого отверстия диска','-')}\n\n"
            f"({current+1}/{len(results)})"
        )

        kb = telebot.types.InlineKeyboardMarkup(row_width=2)
        kb.add(
            telebot.types.InlineKeyboardButton("⬅️ Назад", callback_data=f"prev_{current}"),
            telebot.types.InlineKeyboardButton("➡️ Вперед", callback_data=f"next_{current}")
        )
        kb.add(
            telebot.types.InlineKeyboardButton("❤️ Сохранить", callback_data=f"fav_{current}"),
            telebot.types.InlineKeyboardButton("💬 Связаться", url="https://t.me/Stuttgart_mercedes")
        )

        try:
            if main_photo:
                media = telebot.types.InputMediaPhoto(main_photo, caption=text)
                bot.edit_message_media(
                    media=media,
                    chat_id=chat_id,
                    message_id=call.message.message_id,
                    reply_markup=kb
                )
            else:
                bot.edit_message_caption(
                    caption=text,
                    chat_id=chat_id,
                    message_id=call.message.message_id,
                    reply_markup=kb
                )
        except Exception as e:
            print("Ошибка редактирования:", e)

    else:
        bot.delete_message(chat_id, call.message.message_id)
        send_card(chat_id, current)

    return
