import telebot
import csv

TOKEN = "8668461577:AAHisD8fV_0GqXAXoU57FXOeexTi2x1yI74"

bot = telebot.TeleBot(TOKEN)

CSV_FILE = "parts.csv"

parts_db = []
user_results = {}

# -----------------------------
# Загрузка базы
# -----------------------------

print("Загрузка базы...")

with open(CSV_FILE, encoding="utf-8") as f:
    reader = csv.DictReader(f)

    for row in reader:
        parts_db.append(row)

print("База загружена:", len(parts_db))


# -----------------------------
# Нормализация текста
# -----------------------------

def normalize(text):

    if not text:
        return ""

    text = str(text).lower()
    text = text.replace(" ", "")
    text = text.replace("-", "")
    text = text.replace(",", "")

    return text


# -----------------------------
# Поиск детали
# -----------------------------

def find_part(query):

    query = normalize(query)

    results = []

    for part in parts_db:

        number = normalize(part.get("number", ""))
        name = normalize(part.get("name", ""))

        if query in number or query in name:
            results.append(part)

    return results


# -----------------------------
# Отправка детали
# -----------------------------

def send_part(chat_id, part, index, total):

    name = part.get("name", "Не указано")
    number = part.get("number", "")
    auto = part.get("auto", "")
    price = part.get("price", "")
    photos = part.get("photo", "")

    text = (
        f"🔧 {name}\n"
        f"Номер: {number}\n"
        f"Авто: {auto}\n"
        f"Цена: {price} ₽\n\n"
        f"📦 {index+1} из {total}"
    )

    photo_list = []

    if photos:
        photo_list = photos.split(",")

    if photo_list and photo_list[0]:

        try:
            bot.send_photo(
                chat_id,
                photo_list[0],
                caption=text
            )

            for p in photo_list[1:]:
                p = p.strip()
                if p:
                    bot.send_photo(chat_id, p)

        except:
            bot.send_message(chat_id, text)

    else:
        bot.send_message(chat_id, text)


# -----------------------------
# START
# -----------------------------

@bot.message_handler(commands=["start"])
def start(msg):

    kb = telebot.types.ReplyKeyboardMarkup(resize_keyboard=True)

    kb.row("📦 Как искать", "📞 Менеджер")
    kb.row("🌐 Наш сайт")

    bot.send_message(
        msg.chat.id,
        "🚗 Бот поиска автозапчастей\n\n"
        "Введите номер детали\n"
        "Например:\n"
        "A2095453308",
        reply_markup=kb
    )


