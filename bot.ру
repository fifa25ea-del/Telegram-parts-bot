import requests
import xml.etree.ElementTree as ET
from telegram import Update
from telegram.ext import Updater, CommandHandler, MessageHandler, Filters, CallbackContext

TOKEN = "8668461577:AAHisD8fV_0GqXAXoU57FXOeexTi2x1yI74"
XML_URL = "https://baz-on.ru/export/c592/ca617/drom-140001-parts.xml"

parts_db = []

def load_parts():

    print("Загружаю базу запчастей...")

    r = requests.get(XML_URL)
    root = ET.fromstring(r.content)

    for part in root.findall(".//part"):

        title = part.find("title")
        price = part.find("price")
        number = part.find("manufactureNumber")

        photos = []
        photo_urls = part.find("photoUrls")

        if photo_urls is not None:
            for p in photo_urls.findall("photoUrl"):
                photos.append(p.text)

        parts_db.append({
            "number": number.text if number is not None else "",
            "name": title.text if title is not None else "",
            "price": price.text if price is not None else "",
            "photo": photos[0] if photos else None
        })

    print("База загружена:", len(parts_db), "деталей")


def start(update: Update, context: CallbackContext):

    update.message.reply_text(
        "🚗 Бот поиска запчастей\n\n"
        "Введите номер детали или название."
    )


def search(update: Update, context: CallbackContext):

    query = update.message.text.lower()

    results = []

    for part in parts_db:

        if query in part["number"].lower() or query in part["name"].lower():
            results.append(part)

        if len(results) >= 5:
            break

    if not results:
        update.message.reply_text("❌ Ничего не найдено")
        return

    for part in results:

        text = f"""
🚗 {part['name']}

🔧 Номер: {part['number']}
💰 Цена: {part['price']} ₽
"""

        if part["photo"]:
            update.message.reply_photo(part["photo"], caption=text)
        else:
            update.message.reply_text(text)


def main():

    load_parts()

    updater = Updater(TOKEN)

    dp = updater.dispatcher

    dp.add_handler(CommandHandler("start", start))
    dp.add_handler(MessageHandler(Filters.text & ~Filters.command, search))

    print("BOT STARTED")

    updater.start_polling()
    updater.idle()


if __name__ == "__main__":
    main()
if __name__ == "__main__":
    main()
