# ===== УМНЫЙ ПОИСК =====
def smart_search(query, db):
    words = query.lower().split()
    scored = []

    for item in db:
        text = str(item).lower()
        score = 0

        for w in words:
            if w in text:
                score += 1

        if score > 0:
            scored.append((score, item))

    scored.sort(key=lambda x: x[0], reverse=True)

    return [x[1] for x in scored[:10]]

