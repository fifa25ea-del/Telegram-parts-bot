@bot.callback_query_handler(func=lambda call: True)
def callback(call):

    chat_id = call.message.chat.id

    if call.data.startswith("next"):

        index = int(call.data.split("_")[1]) + 1

        if index >= len(user_results[chat_id]):
            index = 0

        send_card(chat_id, index)

    elif call.data.startswith("prev"):

        index = int(call.data.split("_")[1]) - 1

        if index < 0:
            index = len(user_results[chat_id]) - 1

        send_card(chat_id, index)

    elif call.data.startswith("buy"):

        index = int(call.data.split("_")[1])

        part = user_results[chat_id][index]

        article = part.get("Артикул", "")
        name = part.get(name_key, "")
        price = part.get("Цена", "")

        text = f"Здравствуйте! Хочу купить деталь:\n{name}\nАртикул: {article}\nЦена: {price}"

        link = f"https://t.me/{MANAGER}?text={urllib.parse.quote(text)}"

        bot.send_message(
            chat_id,
            f"Для покупки напишите менеджеру:\n{link}"
        )


